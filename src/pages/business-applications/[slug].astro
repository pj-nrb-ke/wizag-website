---
import ShellPage from '../../components/layout/ShellPage.astro';
import { businessApplications } from '../../data/navigation';

/**
 * WIZAG business application pages — shells pending real product content.
 *
 * Only WIZAG's own products appear here. TimeTrax, MobiSales and CrownEHR
 * run on wizag.co.ke subdomains but belong to another company and must never
 * be listed as WIZAG products.
 */
export function getStaticPaths() {
  /* Products with their own written page, excluded from this shell route so
     the two cannot collide — add here whenever a real page lands.
     Declared INSIDE the function: Astro hoists getStaticPaths out of module
     scope, so a const alongside it would be undefined at call time. */
  const WRITTEN = ['/wizcrm', '/teamkazi'];

  return businessApplications
    .filter((item) => !WRITTEN.some((slug) => item.href.endsWith(slug)))
    .map((item) => ({
      params: { slug: item.href.replace('/business-applications/', '') },
      props: { item },
    }));
}

const { item } = Astro.props;
---

<ShellPage
  title={item.label}
  description={`${item.label} — a WIZAG business application.`}
  lead={`Product detail for ${item.label} is being prepared.`}
  eyebrow="Business Applications"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Business Applications', href: '/business-applications' },
  ]}
  covers={[
    'What it does',
    'Who it is for',
    'Core functionality',
    'Implementation and setup',
    'Integration with your other systems',
    'Support and roadmap',
  ]}
/>
