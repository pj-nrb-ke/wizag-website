---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import SystemsMesh from '../../components/diagrams/SystemsMesh.astro';
import VisitCaptureDemo from '../../components/diagrams/VisitCaptureDemo.astro';
import { wizcrm, problems, aiTrio, platform, trust } from '../../data/wizcrm';
import { wizcrmMesh } from '../../data/mesh';

/**
 * WizCRM product page. Content extracted from docs/BROCHURE-FEATURES.md,
 * following that document's own suggested flow: hook → problem → the AI trio
 * → what's under the hood → trust → call to action.
 *
 * Three design decisions worth recording, all of which reinterpret the
 * original request rather than executing it literally:
 *
 *  1. The hero visual is a working demo of AI Visit Capture, not an
 *     illustration "about AI". The proposition is demonstrated instead of
 *     asserted, and it is the one thing a competitor cannot copy from a
 *     screenshot.
 *
 *  2. The photography brief is field-specific, not the requested
 *     multi-ethnic team at laptops. This product sells to Kenyan field-sales
 *     teams; a rep at a customer counter is both more differentiating and
 *     more honest than a stock boardroom. See ImageSlot for each shot brief.
 *
 *  3. Animation demonstrates rather than decorates. The only substantial
 *     motion on the page is the report assembling itself; everything else is
 *     the site's standard scroll reveal.
 *
 * ⚠ No figure, client or claim appears here that is not in the source
 * brochure document.
 */
---

<BaseLayout
  title="WizCRM — the CRM that writes itself"
  description={wizcrm.positioning}
>
  <!-- HERO ------------------------------------------------------------- -->
  <section class="relative isolate overflow-hidden bg-navy-800 on-deep">
    <Container class="py-12 md:py-14 lg:py-16">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-navy-100">
          <li><a href="/" class="py-1 transition-colors hover:text-paper">Home</a></li>
          <li aria-hidden="true"><Icon name="chevron-down" size={13} class="-rotate-90" /></li>
          <li>
            <a href="/business-applications" class="py-1 transition-colors hover:text-paper">
              Business Applications
            </a>
          </li>
          <li aria-hidden="true"><Icon name="chevron-down" size={13} class="-rotate-90" /></li>
          <li aria-current="page" class="py-1 font-semibold text-paper">WizCRM</li>
        </ol>
      </nav>

      <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:gap-14">
        <div>
          <p class="eyebrow text-orange-500">WizCRM</p>

          <h1 class="optical-left mt-4 max-w-[15ch] text-[length:var(--text-5xl)] leading-[1.08] text-paper">
            {wizcrm.hook}
          </h1>

          <p class="mt-6 max-w-[52ch] text-[length:var(--text-lg)] leading-relaxed text-navy-100">
            {wizcrm.positioning}
          </p>

          <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:gap-7">
            <Button href="/contact" variant="primary" arrow>Request a Demo</Button>
            <a
              href="#how-it-works"
              class="group inline-flex items-center gap-2 py-1 text-base font-semibold text-paper
                     underline-offset-4 transition-colors duration-[var(--duration-fast)]
                     hover:text-orange-500 hover:underline"
            >
              See how it works
              <span
                class="transition-transform duration-[var(--duration-fast)] motion-safe:group-hover:translate-x-0.5"
                aria-hidden="true">→</span
              >
            </a>
          </div>

          <p class="mt-8 text-sm font-medium text-navy-100/75">{wizcrm.audience}</p>
        </div>

        {/* Two columns of WizCRM capability, one scrolling up and one down —
            the same component and behaviour as the homepage hero, in its
            contained `panel` form. The parent must be position:relative for
            the mesh to fill it. */}
        <div class="relative h-[26rem] overflow-hidden rounded-[var(--radius-lg)] border border-navy-500/40 bg-navy-900/45 sm:h-[30rem] lg:h-[32rem]">
          <SystemsMesh items={wizcrmMesh} columns={2} variant="panel" />
        </div>
      </div>
    </Container>
  </section>

  <!-- THE DEMO ---------------------------------------------------------
       Moved out of the AI Visit Capture row once real photography arrived:
       the photo shows the moment, this shows the result, and both are
       stronger with room of their own. Placed immediately after the hero so
       the headline claim is proved before anything else is asked of the
       reader. -->
  <Section tone="paper">
    <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="Twenty seconds" measure="max-w-[15ch]">
          Watch it write the report
        </SectionHeading>
        <p class="mt-5 max-w-[46ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
          The rep says what happened. WizCRM drafts the outcome, who was met, the competitor
          mentioned, the objection raised, the next step and its due date — then hands it
          back for a glance and a tap.
        </p>
        <p class="mt-4 max-w-[46ch] text-base leading-relaxed text-ink-soft">
          Nothing is filed without the rep seeing it. The AI drafts; the person decides.
        </p>
      </div>

      <div data-reveal data-reveal-delay="120">
        <VisitCaptureDemo />
      </div>
    </div>
  </Section>

  <!-- THE PROBLEM ------------------------------------------------------ -->
  <Section tone="warm">
    <SectionHeading
      eyebrow="The problem"
      lead="Every CRM promises a clean pipeline. Almost none survive contact with a field team, because they all depend on reps typing up their day."
      measure="max-w-[20ch]"
      class="max-w-3xl"
      data-reveal
    >
      The pipeline shows yesterday, not today
    </SectionHeading>

    <ul class="mt-10 grid gap-5 sm:grid-cols-3">
      {
        problems.map((item, i) => (
          <li
            class="rounded-[var(--radius-md)] border border-grey-100 bg-paper p-6"
            data-reveal
            data-reveal-delay={i * 70}
          >
            <Icon name={item.icon} size={22} class="text-orange-500" />
            <h3 class="mt-4 text-[length:var(--text-2xl)] leading-snug text-navy-700">
              {item.title}
            </h3>
            <p class="mt-2.5 text-base leading-relaxed text-ink">{item.body}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  <!-- THE AI TRIO ------------------------------------------------------ -->
  <Section tone="paper" id="how-it-works">
    <SectionHeading
      eyebrow="How it works"
      lead="Three AI capabilities that between them write the reports, run the daily rhythm, and fill the pipeline."
      measure="max-w-[18ch]"
      class="max-w-3xl"
      data-reveal
    >
      The work nobody has time for, done
    </SectionHeading>

    <div class="mt-12 grid gap-y-12">
      {
        aiTrio.map((feature, idx) => (
          <div
            class:list={[
              'grid items-start gap-8 border-t border-grey-300 pt-9 lg:grid-cols-2 lg:gap-14',
              idx % 2 === 1 && 'lg:[&>*:first-child]:order-2',
            ]}
            data-reveal
          >
            <div>
              <div class="flex items-center gap-3">
                <Icon name={feature.icon} size={22} class="text-orange-500" />
                <span class="font-mono text-xs font-bold tracking-[0.14em] text-orange-700">
                  {feature.n}
                </span>
              </div>

              <h3 class="mt-4 text-[length:var(--text-3xl)] leading-snug text-navy-700">
                {feature.name}
              </h3>
              <p class="mt-1.5 text-[length:var(--text-lg)] font-medium text-orange-700">
                {feature.tagline}
              </p>
              <p class="mt-4 max-w-[48ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
                {feature.intro}
              </p>

              <ul class="mt-6">
                {feature.points.map((point) => (
                  <li class="flex items-start gap-3 border-t border-grey-300 py-3 text-base leading-relaxed text-ink">
                    <Icon name="check" size={16} class="mt-1.5 shrink-0 text-orange-700" />
                    {point}
                  </li>
                ))}
              </ul>
            </div>

            {/* One photograph per capability — each briefed to the specific
                moment that capability serves, not a generic office scene. */}
            <div class="lg:sticky lg:top-28">
              {idx === 0 && (
                <img
                  src="/images/wizcrm/wizcrm-visit-capture.jpg"
                  alt="A sales representative standing outside a hardware shop, speaking a visit note into their phone, a folder under one arm."
                  width="760"
                  height="504"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-[var(--radius-md)] object-cover"
                />
              )}
              {idx === 1 && (
                <img
                  src="/images/wizcrm/wizcrm-morning-brief.jpg"
                  alt="A sales manager at a desk in the early morning, reading a laptop screen with a cup of tea beside them."
                  width="760"
                  height="504"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-[var(--radius-md)] object-cover"
                />
              )}
              {idx === 2 && (
                <img
                  src="/images/wizcrm/wizcrm-prospecting.jpg"
                  alt="Two colleagues at a desk reviewing a prospect list on a laptop together, seen from behind."
                  width="760"
                  height="504"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-[var(--radius-md)] object-cover"
                />
              )}
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- UNDER THE HOOD --------------------------------------------------- -->
  <Section tone="warm">
    <SectionHeading
      eyebrow="Under the hood"
      lead="Everything the AI sits on top of — a complete CRM in its own right."
      measure="max-w-[18ch]"
      class="max-w-3xl"
      data-reveal
    >
      The platform underneath
    </SectionHeading>

    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      {
        platform.map((block, i) => (
          <div
            class="rounded-[var(--radius-md)] border border-grey-100 bg-paper p-6 sm:p-7"
            data-reveal
            data-reveal-delay={Math.min(i, 3) * 60}
          >
            <Icon name={block.icon} size={22} class="text-orange-500" />
            <h3 class="mt-4 text-[length:var(--text-2xl)] leading-snug text-navy-700">
              {block.name}
            </h3>
            <p class="mt-2 text-base leading-relaxed text-ink-soft">{block.hook}</p>

            <ul class="mt-5">
              {block.points.map((point) => (
                <li class="flex items-start gap-2.5 border-t border-grey-300 py-2.5 text-base leading-relaxed text-ink">
                  <Icon name="check" size={16} class="mt-1.5 shrink-0 text-orange-700" />
                  {point}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- IN THE FIELD ----------------------------------------------------- -->
  <Section tone="paper">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="In the field" measure="max-w-[16ch]">
          Built for reps on the road
        </SectionHeading>
        <p class="mt-5 max-w-[48ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
          Offline-first, GPS-verified, one tap to call or open directions. Everything queues
          and syncs the moment a connection returns — because coverage is not a given, and a
          CRM that needs a signal is a CRM that stays empty.
        </p>
      </div>

      <img
        src="/images/wizcrm/wizcrm-in-the-field.jpg"
        alt="A sales representative beside a dusty pickup truck at the roadside, checking their phone between customer visits."
        width="760"
        height="504"
        loading="lazy"
        decoding="async"
        class="w-full rounded-[var(--radius-md)] object-cover"
        data-reveal
      />
    </div>
  </Section>

  <!-- TRUST ------------------------------------------------------------ -->
  <Section tone="deep">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:gap-16">
      <div data-reveal>
        <p class="eyebrow mb-4 text-orange-500">Trust</p>
        <h2 class="max-w-[16ch] text-[length:var(--text-4xl)] leading-tight text-paper">
          Human-in-the-loop, and auditable
        </h2>
        <p class="mt-5 max-w-[42ch] text-base leading-relaxed text-navy-100">
          The AI drafts; your people decide. Every action it takes is logged, and the privacy
          story was built for Kenya from day one — not retrofitted.
        </p>
      </div>

      <ul class="grid gap-x-10 sm:grid-cols-2" data-reveal data-reveal-delay="100">
        {
          trust.map((item) => (
            <li class="flex items-start gap-3 border-t border-navy-500/40 py-3.5 text-base leading-relaxed text-navy-100">
              <Icon name="check" size={16} class="mt-1.5 shrink-0 text-orange-500" />
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  <!-- CTA -------------------------------------------------------------- -->
  <Section tone="warm" space="tight">
    <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="max-w-[24ch] text-[length:var(--text-3xl)] leading-snug text-navy-700">
          See WizCRM against your own pipeline
        </h2>
        <p class="mt-3 max-w-[52ch] text-base leading-relaxed text-ink">
          We would rather walk through your actual sales process than send a brochure. Bring a
          real deal and we will show you what the AI does with it.
        </p>
      </div>
      <Button href="/contact" variant="primary" size="large" arrow>Request a Demo</Button>
    </div>
  </Section>
</BaseLayout>
