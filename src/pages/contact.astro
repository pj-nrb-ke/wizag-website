---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/layout/PageHero.astro';
import Section from '../components/layout/Section.astro';
import Icon from '../components/ui/Icon.astro';
import { company } from '../data/navigation';

/**
 * Contact.
 *
 * The capture form lands in the next phase, once the endpoint exists:
 * Turnstile → edge function → Zod validation → Postgres → email → WizCRM.
 * Until then this page routes to a real mailbox rather than showing a form
 * that silently fails — a dead form costs more trust than no form.
 */
const { address } = company;

const expectations = [
  'A 30-minute structured conversation, not a sales pitch',
  'We look at your systems, processes and reporting as they are today',
  'You get a plain view of where the value is — and where it is not',
  'No obligation to proceed',
];
---

<BaseLayout
  title="Contact"
  description="Book a business technology assessment with WIZAG. Valley View Office Park, Parklands, Nairobi."
>
  <PageHero
    title="Book a business technology assessment"
    lead="Tell us what you are trying to improve. We will look at your systems, operational bottlenecks and transformation priorities, and tell you plainly where we can help."
    eyebrow="Contact"
    crumbs={[{ label: 'Home', href: '/' }]}
  />

  <Section tone="paper">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div data-reveal>
        <p class="eyebrow mb-4 text-ink-soft">What to expect</p>
        <ul>
          {
            expectations.map((item) => (
              <li class="flex items-start gap-3 border-t border-grey-300 py-4 text-[length:var(--text-lg)] text-ink">
                <Icon name="check" size={16} class="mt-1 shrink-0 text-orange-700" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div data-reveal data-reveal-delay="100">
        <div class="rounded-[var(--radius-lg)] border border-grey-100 bg-warm p-7 sm:p-9">
          <p class="eyebrow mb-4 text-ink-soft">Get in touch</p>

          <a
            href={`mailto:${company.email}?subject=Business%20technology%20assessment`}
            class="group inline-flex items-center gap-3 text-[length:var(--text-2xl)] font-semibold text-navy-700 transition-colors duration-[var(--duration-fast)] hover:text-orange-700"
          >
            <Icon name="mail" size={20} class="text-orange-500" />
            {company.email}
          </a>

          <p class="mt-4 text-base leading-relaxed text-ink">
            Email is the fastest route to a real answer. Tell us the systems you run and what
            is not working, and we will come back with specifics.
          </p>

          <hr class="my-7 border-grey-300" />

          <p class="eyebrow mb-3 text-ink-soft">Office</p>
          <address class="space-y-1 text-base not-italic leading-relaxed text-ink">
            <div class="font-semibold text-navy-700">{address.building}</div>
            <div>{address.unit}</div>
            <div>{address.street}</div>
            <div>{address.area}, {address.city}</div>
            <div>{address.country}</div>
          </address>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
