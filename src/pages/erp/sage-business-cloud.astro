---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import SagePartnerBadge from '../../components/ui/SagePartnerBadge.astro';
import SageReportingDemo from '../../components/diagrams/SageReportingDemo.astro';
import StepFlow from '../../components/diagrams/StepFlow.astro';
import {
  sage,
  partnerNote,
  taxNote,
  modules,
  reports,
  debtorsSteps,
  autoEntrySteps,
  inventoryPoints,
  currencyPoints,
  wizagRole,
} from '../../data/sage-business-cloud';

/**
 * Sage Business Cloud Accounting. Content extracted from the client's
 * brochure (Dropbox/SageAccounting_Brochure_v2.html).
 *
 * ⚠ THE SOURCE BROCHURE IS SOUTH AFRICAN. It cites SARS six times, "South
 * African regulatory requirements", "Province" as an analysis-code example
 * and Domestic Reverse Charges on valuable metals. None of that survives
 * here — see the header comment in src/data/sage-business-cloud.ts for the
 * full list of what was dropped and why, including four unverifiable
 * statistics.
 *
 * No scrolling mesh on this page, by instruction. The motion budget goes on
 * three things that carry meaning instead: the dashboard assembling itself,
 * the collections cycle running without anyone driving it, and the capture
 * flow. All three are static and fully readable under reduced motion.
 *
 * Panels are WIZAG navy and orange, not Sage green — this is WIZAG's page
 * about a product it implements, and a green panel mid-site reads as a
 * pasted screenshot.
 */
---

<BaseLayout title={`${sage.shortName} — ${sage.hook}`} description={sage.positioning}>
  <!-- HERO ------------------------------------------------------------- -->
  <section class="relative isolate overflow-hidden bg-navy-800 on-deep">
    <Container class="py-12 md:py-14 lg:py-16">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-navy-100">
          <li><a href="/" class="py-1 transition-colors hover:text-paper">Home</a></li>
          <li aria-hidden="true"><Icon name="chevron-down" size={13} class="-rotate-90" /></li>
          <li><a href="/erp" class="py-1 transition-colors hover:text-paper">ERP</a></li>
          <li aria-hidden="true"><Icon name="chevron-down" size={13} class="-rotate-90" /></li>
          <li aria-current="page" class="py-1 font-semibold text-paper">{sage.shortName}</li>
        </ol>
      </nav>

      <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:gap-14">
        <div>
          <p class="eyebrow text-orange-500">{sage.name}</p>

          <h1 class="optical-left mt-4 max-w-[16ch] text-[length:var(--text-5xl)] leading-[1.08] text-paper">
            {sage.hook}
          </h1>

          <p class="mt-6 max-w-[52ch] text-[length:var(--text-lg)] leading-relaxed text-navy-100">
            {sage.positioning}
          </p>

          <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:gap-7">
            <Button href="/contact" variant="primary" arrow>Request a Demo</Button>
            <a
              href="#modules"
              class="group inline-flex items-center gap-2 py-1 text-base font-semibold text-paper
                     underline-offset-4 transition-colors duration-[var(--duration-fast)]
                     hover:text-orange-500 hover:underline"
            >
              See what it covers
              <span
                class="transition-transform duration-[var(--duration-fast)] motion-safe:group-hover:translate-x-0.5"
                aria-hidden="true">→</span
              >
            </a>
          </div>

          <p class="mt-8 text-sm font-medium text-navy-100/75">{sage.audience}</p>
        </div>

        <div>
          <SageReportingDemo />
        </div>
      </div>
    </Container>
  </section>

  <!-- THE TWELVE MODULES ----------------------------------------------- -->
  <Section tone="paper" id="modules">
    <SectionHeading
      eyebrow="What it covers"
      lead="Twelve modules. Four of them are add-ons, and we have marked which — finding that out at quotation stage is a bad way to start a relationship."
      measure="max-w-[18ch]"
      class="max-w-3xl"
      data-reveal
    >
      One system instead of six spreadsheets
    </SectionHeading>

    <ul class="mt-10 grid gap-x-8 gap-y-0 sm:grid-cols-2 lg:grid-cols-3">
      {
        modules.map((m, i) => (
          <li
            class="border-t border-grey-300 py-6"
            data-reveal
            data-reveal-delay={Math.min(i, 5) * 50}
          >
            <div class="flex items-center gap-3">
              <Icon name={m.icon} size={20} class="text-orange-500" />
              {m.addOn && (
                <span class="rounded-full bg-warm px-2 py-0.5 font-mono text-[length:var(--text-2xs)] font-bold uppercase tracking-[0.1em] text-orange-700">
                  Add-on
                </span>
              )}
            </div>
            <h3 class="mt-3 text-[length:var(--text-xl)] font-bold leading-snug text-navy-700">
              {m.name}
            </h3>
            <p class="mt-1.5 text-base leading-relaxed text-ink">{m.body}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  <!-- REPORTING -------------------------------------------------------- -->
  <Section tone="warm">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="Reporting" measure="max-w-[17ch]">
          Stop waiting for month-end to know where you stand
        </SectionHeading>
        <p class="mt-5 max-w-[48ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
          The reports run against live data rather than a reconstruction assembled three weeks
          after the fact. That changes what they are for: not a record of what happened, but
          something you can act on while it still matters.
        </p>

        <ul class="mt-8">
          {
            reports.map((r) => (
              <li class="border-t border-grey-300 py-3.5">
                <h3 class="text-base font-bold text-navy-700">{r.name}</h3>
                <p class="mt-1 text-base leading-relaxed text-ink">{r.body}</p>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="lg:sticky lg:top-28 lg:self-start" data-reveal data-reveal-delay="120">
        <img
          src="/images/sage/sage-reporting.jpg"
          alt="A business owner seen from behind at a desk, holding a printed report beside an open laptop, with manila folders and a calculator on the desk."
          width="930"
          height="620"
          loading="lazy"
          decoding="async"
          class="w-full rounded-[var(--radius-md)] object-cover"
        />
      </div>
    </div>
  </Section>

  <!-- DEBTORS MANAGER -------------------------------------------------- -->
  <Section tone="paper">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="Debtors manager · add-on" measure="max-w-[15ch]">
          Chasing payment, without the chasing
        </SectionHeading>
        <p class="mt-5 max-w-[46ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
          Unpaid invoices are rarely a collections problem. They are a follow-up problem — the
          second reminder that nobody sent because everyone was busy.
        </p>
        <p class="mt-4 max-w-[46ch] text-base leading-relaxed text-ink-soft">
          This runs the sequence on a schedule you define, so the awkward part happens on time
          and in a consistent tone of voice.
        </p>
      </div>

      <div data-reveal data-reveal-delay="120">
        <StepFlow steps={debtorsSteps} orientation="vertical" cycle={16} tone="light" />
      </div>
    </div>
  </Section>

  <!-- INVENTORY + MULTI-CURRENCY --------------------------------------- -->
  <Section tone="warm">
    <SectionHeading
      eyebrow="Stock and currency"
      lead="The two areas where a growing business usually discovers its accounting package has run out of room."
      measure="max-w-[20ch]"
      class="max-w-3xl"
      data-reveal
    >
      Where spreadsheets give up
    </SectionHeading>

    {/* A letterbox band rather than a portrait slot: this section is two
        dense checklists, and a full-height image beside them would crowd
        both. It works as a divider instead.

        Width-capped deliberately. The source frame is 717px wide — it came
        from one panel of a composite — and letting it span the full column
        would upscale it to ~1184px and visibly soften it. Capped at 48rem it
        renders at roughly 1:1. If a full-bleed band is ever wanted here, the
        shot has to be regenerated on its own at full resolution. */}
    <div class="mx-auto mt-9 max-w-3xl" data-reveal>
      <img
        src="/images/sage/sage-inventory.jpg"
        alt="A stock controller checking a phone in the aisle of a small wholesale storeroom, racking stacked with cartons and sacks either side."
        width="717"
        height="403"
        loading="lazy"
        decoding="async"
        class="w-full rounded-[var(--radius-md)] object-cover"
      />
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-2 lg:gap-14">
      <div
        class="rounded-[var(--radius-md)] border border-grey-100 bg-paper p-6 sm:p-7"
        data-reveal
      >
        <Icon name="erp-systems" size={22} class="text-orange-500" />
        <h3 class="mt-4 text-[length:var(--text-2xl)] leading-snug text-navy-700">Inventory</h3>
        <p class="mt-2 text-base leading-relaxed text-ink-soft">
          What you hold, what is moving, and when to reorder.
        </p>
        <ul class="mt-5">
          {
            inventoryPoints.map((p) => (
              <li class="flex items-start gap-2.5 border-t border-grey-300 py-2.5 text-base leading-relaxed text-ink">
                <Icon name="check" size={16} class="mt-1.5 shrink-0 text-orange-700" />
                {p}
              </li>
            ))
          }
        </ul>
      </div>

      <div
        class="rounded-[var(--radius-md)] border border-grey-100 bg-paper p-6 sm:p-7"
        data-reveal
        data-reveal-delay="80"
      >
        <Icon name="globe" size={22} class="text-orange-500" />
        <h3 class="mt-4 text-[length:var(--text-2xl)] leading-snug text-navy-700">
          Multi-currency
        </h3>
        <p class="mt-2 text-base leading-relaxed text-ink-soft">
          For anyone importing, exporting or invoicing across a border.
        </p>
        <ul class="mt-5">
          {
            currencyPoints.map((p) => (
              <li class="flex items-start gap-2.5 border-t border-grey-300 py-2.5 text-base leading-relaxed text-ink">
                <Icon name="check" size={16} class="mt-1.5 shrink-0 text-orange-700" />
                {p}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>

  <!-- AUTOENTRY -------------------------------------------------------- -->
  <Section tone="deep">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:gap-16">
      <div data-reveal>
        <p class="eyebrow mb-4 text-orange-500">AutoEntry · add-on</p>
        <h2 class="max-w-[16ch] text-[length:var(--text-4xl)] leading-tight text-paper">
          The end of typing in receipts
        </h2>
        <p class="mt-5 max-w-[42ch] text-base leading-relaxed text-navy-100">
          Document capture reads a receipt, supplier invoice or bank statement and extracts the
          fields. Nothing posts to the books until a person has categorised and approved it.
        </p>
      </div>

      <div data-reveal data-reveal-delay="100">
        <StepFlow steps={autoEntrySteps} orientation="horizontal" cycle={12} tone="deep" />
      </div>
    </div>
  </Section>

  <!-- TAX AND COMPLIANCE ------------------------------------------------
       ⚠ Deliberately does NOT claim a Kenyan compliance certification. The
       source brochure's SARS claims were South African and have been removed
       rather than relabelled. Confirm the product's actual eTIMS position
       with Sage before this page goes live. -->
  <Section tone="paper">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="VAT and tax" measure="max-w-[16ch]">
          Records that are ready before anyone asks
        </SectionHeading>
        <p class="mt-5 max-w-[48ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
          VAT is calculated on every transaction as it is entered, records are kept digitally and
          completely, and returns are prepared with the full calculation visible rather than as a
          number you have to take on trust.
        </p>

        <div
          class="mt-7 rounded-[var(--radius-md)] border-l-[3px] border-orange-500 bg-warm p-5 sm:p-6"
        >
          <p class="text-[length:var(--text-2xs)] font-bold uppercase tracking-[0.11em] text-orange-700">
            On Kenyan compliance
          </p>
          <p class="mt-2.5 max-w-[52ch] text-base leading-relaxed text-ink">{taxNote}</p>
        </div>
      </div>

      <div data-reveal data-reveal-delay="120">
        <img
          src="/images/sage/sage-records.jpg"
          alt="An open box file of neatly filed receipts and slips on a desk beside a laptop, with a stapler and pen alongside."
          width="669"
          height="446"
          loading="lazy"
          decoding="async"
          class="w-full rounded-[var(--radius-md)] object-cover"
        />
      </div>
    </div>
  </Section>

  <!-- WHERE WIZAG COMES IN ---------------------------------------------- -->
  <Section tone="warm">
    <SectionHeading
      eyebrow="Working with WIZAG"
      lead={partnerNote}
      measure="max-w-[18ch]"
      class="max-w-3xl"
      data-reveal
    >
      Software is the easy half
    </SectionHeading>

    {/* Warm section, so the badge's grey "Business Partner" lettering has the
        light ground it was drawn for. It must never go on a navy section —
        see the contrast note in the component. */}
    <div class="mt-7" data-reveal>
      <SagePartnerBadge />
    </div>

    <ul class="mt-10 grid gap-5 sm:grid-cols-3">
      {
        wizagRole.map((item, i) => (
          <li
            class="rounded-[var(--radius-md)] border border-grey-100 bg-paper p-6"
            data-reveal
            data-reveal-delay={i * 70}
          >
            <Icon name={item.icon} size={22} class="text-orange-500" />
            <h3 class="mt-4 text-[length:var(--text-2xl)] leading-snug text-navy-700">
              {item.title}
            </h3>
            <p class="mt-2.5 text-base leading-relaxed text-ink">{item.body}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  <!-- CTA -------------------------------------------------------------- -->
  <Section tone="deep" space="tight">
    <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="max-w-[24ch] text-[length:var(--text-3xl)] leading-snug text-paper">
          Bring your current month-end
        </h2>
        <p class="mt-3 max-w-[52ch] text-base leading-relaxed text-navy-100">
          We would rather walk through how your books actually close today than send a feature
          list. Bring the spreadsheet everyone dreads and we will show you what replaces it.
        </p>
      </div>
      <Button href="/contact" variant="inverse" size="large" arrow>Request a Demo</Button>
    </div>
  </Section>
</BaseLayout>
