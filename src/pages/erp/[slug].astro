---
import ShellPage from '../../components/layout/ShellPage.astro';
import { erp } from '../../data/navigation';

/**
 * ERP platform pages.
 *
 * Shells for now — kept out of the index until each carries real content.
 * No capability claim appears here until each page is written.
 *
 * Partner wording is settled: the badge Sage issued reads "Sage Business
 * Partner", and that exact phrase is the only designation to use. See
 * partnerNote in src/data/sage-business-cloud.ts and the SagePartnerBadge
 * component. Do not embellish it on these pages when they are written.
 */
export function getStaticPaths() {
  /* Platforms with their own written page, excluded so the routes cannot
     collide. Declared INSIDE the function: Astro hoists getStaticPaths out
     of module scope, so a const alongside it would be undefined at call
     time. Add here whenever a real page lands. */
  const WRITTEN = ['/erp/sage-business-cloud'];

  return erp
    .filter((item) => item.href !== '/erp' && !WRITTEN.includes(item.href))
    .map((item) => ({
      params: { slug: item.href.replace('/erp/', '') },
      props: { item },
    }));
}

const { item } = Astro.props;

const covers: Record<string, string[]> = {
  'Sage 200 Evolution': [
    'Implementation approach',
    'Modules and functionality',
    'Migration from legacy systems',
    'Integration with existing tools',
    'Reporting and analytics',
    'Ongoing support options',
  ],
  'Sage Business Cloud': [
    'Cloud accounting setup',
    'Migration and data conversion',
    'Multi-user and multi-company',
    'Integration with existing tools',
    'Reporting',
    'Ongoing support options',
  ],
  WizERP: [
    'Modules and functionality',
    'Where it fits versus Sage',
    'Implementation approach',
    'Customisation and extension',
    'Integration',
    'Support and roadmap',
  ],
  AscendBooks: [
    'Overview and positioning',
    'Core functionality',
    'Who it suits',
    'Implementation approach',
    'Integration',
    'Support options',
  ],
};
---

<ShellPage
  title={item.label}
  description={`${item.label} — implementation, migration, integration and support from WIZAG.`}
  lead={`Implementation, migration, integration and ongoing support for ${item.label}.`}
  eyebrow="ERP"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'ERP', href: '/erp' },
  ]}
  covers={covers[item.label] ?? []}
/>
