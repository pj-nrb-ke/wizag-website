---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import { differentiators } from '../../data/home';
import { about, company } from '../../data/navigation';

/**
 * Company overview.
 *
 * Deliberately carries no founding year, headcount or project count: public
 * directories disagree on all three (founding is listed as both 2013 and
 * 2003), and the brief forbids unverified figures. Add them once the client
 * confirms — they belong here more than anywhere else on the site.
 */
const sub = about.filter((item) => item.href !== '/about');
const { address } = company;
---

<BaseLayout
  title="About WIZAG"
  description="Wise & Agile Solutions Ltd is an enterprise transformation and technology services company based in Nairobi, Kenya."
>
  <PageHero
    title="More than a technology vendor"
    lead="WIZAG helps organisations improve how they operate — through executive technology leadership, ERP and business systems, AI, process improvement, data, and ongoing managed services."
    eyebrow="About WIZAG"
    crumbs={[{ label: 'Home', href: '/' }]}
  />

  <Section tone="paper">
    <div class="grid gap-x-16 gap-y-0 md:grid-cols-2">
      {
        differentiators.map((item) => (
          <div class="border-t border-grey-300 py-8" data-reveal>
            <h2 class="text-[length:var(--text-3xl)] leading-snug text-navy-700">{item.title}</h2>
            <p class="mt-3 max-w-[46ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
              {item.body}
            </p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section tone="warm">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="Where we are" measure="max-w-[16ch]">
          Based in Nairobi, working across the region
        </SectionHeading>

        <address class="mt-8 space-y-1 text-[length:var(--text-lg)] not-italic leading-relaxed text-ink">
          <div class="font-semibold text-navy-700">{address.building}</div>
          <div>{address.unit}</div>
          <div>{address.street}</div>
          <div>{address.area}, {address.city}</div>
          <div>{address.country}</div>
        </address>

        <a
          href={`mailto:${company.email}`}
          class="mt-6 inline-flex items-center gap-2 py-1 text-[length:var(--text-lg)] font-semibold text-navy-700 transition-colors duration-[var(--duration-fast)] hover:text-orange-700"
        >
          <Icon name="mail" size={16} />
          {company.email}
        </a>
      </div>

      <div data-reveal data-reveal-delay="100">
        <p class="eyebrow mb-4 text-ink-soft">More about WIZAG</p>
        <ul>
          {
            sub.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="group flex items-center justify-between gap-4 border-t border-grey-300 py-5 text-[length:var(--text-2xl)] font-semibold text-navy-700 transition-colors duration-[var(--duration-fast)] hover:text-orange-700"
                >
                  {item.label}
                  <Icon
                    name="arrow-right"
                    size={16}
                    class="shrink-0 text-grey-500 transition-all duration-[var(--duration-fast)] group-hover:text-orange-700 motion-safe:group-hover:translate-x-0.5"
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>

  <Section tone="deep" space="tight">
    <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="text-[length:var(--text-3xl)] text-paper">Let's talk about your operation</h2>
        <p class="mt-3 max-w-[52ch] text-base text-navy-100">
          A short, structured conversation about where technology is helping and where it is
          getting in the way.
        </p>
      </div>
      <Button href="/contact" variant="inverse" size="large" arrow>Book an Assessment</Button>
    </div>
  </Section>
</BaseLayout>
