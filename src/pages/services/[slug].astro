---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import ImageSlot from '../../components/ui/ImageSlot.astro';
import PracticeShift from '../../components/diagrams/PracticeShift.astro';
import { practices, practiceShift, practiceImage } from '../../data/services';

/**
 * Service practice detail pages — one per practice, generated from the
 * brief §6 content. Six real pages, not stubs.
 *
 * These were the last text-only pages on the site: two bullet lists and a
 * call to action, against product pages carrying working diagrams and
 * photography. Each now leads with the PracticeShift diagram — the brief's
 * outcomes paired with the conditions they replace — followed by a
 * photograph, so the services read as the same calibre of offering as the
 * products.
 *
 * The shift diagram deliberately comes BEFORE the capability list. A buyer
 * decides whether a practice is for them from the problem, not from an
 * inventory of what we can do; the capabilities then answer "how", which is
 * the second question and never the first.
 */
export function getStaticPaths() {
  return practices.map((practice) => ({
    params: { slug: practice.slug },
    props: { practice },
  }));
}

const { practice } = Astro.props;
const others = practices.filter((p) => p.slug !== practice.slug);
const shift = practiceShift[practice.slug] ?? [];
const image = practiceImage[practice.slug];
---

<BaseLayout
  title={practice.title}
  description={practice.positioning}
>
  <PageHero
    title={practice.title}
    lead={practice.positioning}
    eyebrow="Services"
    crumbs={[{ label: 'Services', href: '/services' }]}
  />

  <!-- The shift — the problem first, the outcome second -->
  {
    shift.length > 0 && (
      <Section tone="paper">
        <SectionHeading
          eyebrow="What changes"
          lead="Most organisations arrive at this practice from a recognisable place. This is the distance it covers."
          measure="max-w-[16ch]"
          class="max-w-3xl"
          data-reveal
        >
          From where you are, to where this gets you
        </SectionHeading>

        <div class="mt-10" data-reveal>
          <PracticeShift pairs={shift} />
        </div>
      </Section>
    )
  }

  <!-- What's included -->
  <Section tone="warm">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="What's included" measure="max-w-[14ch]">
          Capabilities in this practice
        </SectionHeading>
        <p class="mt-5 max-w-[42ch] text-base leading-relaxed text-ink">
          Engagements draw on whichever of these the situation needs. Very few use all of them,
          and we will say which we think apply before you commit to anything.
        </p>
      </div>

      <ul class="grid gap-x-10 gap-y-0 sm:grid-cols-2" data-reveal data-reveal-delay="100">
        {
          practice.capabilities.map((capability) => (
            <li class="flex items-start gap-3 border-t border-grey-300 py-3.5 text-base text-ink">
              <Icon name="check" size={16} class="mt-1 shrink-0 text-orange-700" />
              {capability}
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  <!-- The practice in the room -->
  {
    image && (
      <Section tone="paper">
        <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:gap-16">
          <div data-reveal>
            <SectionHeading eyebrow="Working together" measure="max-w-[15ch]">
              How this actually runs
            </SectionHeading>
            <p class="mt-5 max-w-[46ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
              Short engagements with named people, agreed outcomes and a decision point at the
              end of each stage. You always know what is being worked on and what it is for.
            </p>
            <p class="mt-4 max-w-[46ch] text-base leading-relaxed text-ink-soft">
              Most engagements start in one practice and grow into others as the operating
              picture becomes clearer — which is a decision you make later, not a commitment you
              make now.
            </p>
          </div>

          {/* A real photograph where one exists; the documented placeholder
              otherwise, so an unfinished practice page is obvious rather than
              quietly empty. */}
          {
            image.file ? (
              <img
                src={`/images/services/${image.file}`}
                alt={image.alt}
                width={image.w}
                height={image.h}
                loading="lazy"
                decoding="async"
                class="w-full rounded-[var(--radius-md)] object-cover"
                data-reveal
                data-reveal-delay="120"
              />
            ) : (
              <ImageSlot
                ratio="4/3"
                brief={image.brief}
                purpose={image.purpose}
                data-reveal
                data-reveal-delay="120"
              />
            )
          }
        </div>
      </Section>
    )
  }

  <!-- CTA -->
  <Section tone="deep" space="tight">
    <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="text-[length:var(--text-3xl)] text-paper">{practice.cta}</h2>
        <p class="mt-3 max-w-[52ch] text-base text-navy-100">
          Tell us what you are trying to improve and we will tell you, plainly, whether we
          are the right people for it.
        </p>
      </div>
      <Button href={practice.ctaHref} variant="inverse" size="large" arrow>
        Book an Assessment
      </Button>
    </div>
  </Section>

  <!-- Other practices -->
  <Section tone="paper">
    <SectionHeading eyebrow="Also in services" measure="max-w-[20ch]" data-reveal>
      Other practices
    </SectionHeading>

    <ul class="mt-7 grid gap-x-10 gap-y-0 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-12">
      {
        others.map((other) => (
          <li class="group border-t border-grey-300 py-6" data-reveal>
            <a href={`/services/${other.slug}`} class="block">
              <Icon name={other.icon} size={20} class="text-orange-500" />
              <h3 class="mt-3 text-[length:var(--text-2xl)] leading-snug text-navy-700">
                {other.title}
              </h3>
              <p class="mt-2 text-base leading-relaxed text-ink">{other.positioning}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-base font-semibold text-navy-700 group-hover:text-orange-700">
                Learn more
                <Icon name="arrow-right" size={16} />
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>
</BaseLayout>
