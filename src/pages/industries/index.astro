---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import IndustryModel from '../../components/diagrams/IndustryModel.astro';
import { industries } from '../../data/industries';

/**
 * Industries index.
 *
 * Rebuilt 2026-07-23 alongside the sector pages. The previous version was a
 * hero, one feature card with hand-written manufacturing copy, and eight
 * bare links. It now reads from the industries data (so the index and the
 * pages can never disagree), leads with the model that every sector page
 * shares — WIZAG works on the layer around your system of record — and gives
 * every sector a positioning line and its icon rather than a bare label.
 *
 * Manufacturing keeps the feature slot (brief §8.8: deepest sector
 * experience) and is picked up from the `feature` flag rather than by
 * position, so re-ordering the data cannot silently change the hero.
 */
const feature = industries.find((i) => i.feature) ?? industries[0]!;
const rest = industries.filter((i) => i.slug !== feature.slug);
---

<BaseLayout
  title="Industries"
  description="Industry experience across manufacturing, financial services, retail and distribution, logistics, healthcare, education, professional services, NGOs and the public sector."
>
  <PageHero
    title="Industry experience that connects technology to operations"
    lead="The systems are similar across sectors. What differs is how the work actually flows — and, increasingly, which national system you are required to run. That is where implementations succeed or fail."
    eyebrow="Industries"
    crumbs={[{ label: 'Home', href: '/' }]}
  />

  <!-- THE MODEL EVERY SECTOR PAGE SHARES ------------------------------- -->
  <Section tone="paper">
    <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-16">
      <div data-reveal>
        <SectionHeading eyebrow="How we fit" measure="max-w-[17ch]">
          We work around the system you already run
        </SectionHeading>
        <p class="mt-5 max-w-[48ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
          Several of these sectors now have a system of record set by a regulator — IFMIS and
          e-GP in the public sector, an accredited hospital system under the Social Health
          Authority, KEMIS in education, a SASRA-regulated core in financial services. You do
          not choose those, and we do not replace them.
        </p>
        <p class="mt-4 max-w-[48ch] text-base leading-relaxed text-ink-soft">
          What we build is the finance, process, reporting and integration layer around
          whatever sits at the centre — and, where that centre is one of our own ERP
          products, we build that too. It is the same model in every sector; only the centre
          changes.
        </p>
      </div>

      <div data-reveal data-reveal-delay="120">
        <IndustryModel />
      </div>
    </div>
  </Section>

  <!-- FEATURE: MANUFACTURING ------------------------------------------- -->
  <Section tone="warm">
    <a
      href={`/industries/${feature.slug}`}
      class="group grid gap-6 border-t-2 border-navy-700 pt-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:gap-12"
      data-reveal
    >
      <div>
        <div class="flex items-center gap-3">
          <Icon name={feature.icon} size={26} class="text-orange-500" />
          <span class="eyebrow text-ink-soft">Deepest sector experience</span>
        </div>
        <h2
          class="mt-4 text-[length:var(--text-4xl)] leading-tight text-navy-700 transition-colors duration-[var(--duration-fast)] group-hover:text-orange-700"
        >
          {feature.title}
        </h2>
      </div>
      <div>
        <p class="text-[length:var(--text-lg)] leading-relaxed text-ink">
          {feature.lead}
        </p>
        <span
          class="mt-5 inline-flex items-center gap-1.5 text-base font-semibold text-navy-700 group-hover:text-orange-700"
        >
          Explore {feature.short.toLowerCase()}
          <Icon
            name="arrow-right"
            size={16}
            class="transition-transform duration-[var(--duration-fast)] motion-safe:group-hover:translate-x-0.5"
          />
        </span>
      </div>
    </a>
  </Section>

  <!-- THE REST --------------------------------------------------------- -->
  <Section tone="paper">
    <SectionHeading eyebrow="Every sector" measure="max-w-[20ch]" data-reveal>
      The industries we work in
    </SectionHeading>

    <ul class="mt-10 grid gap-x-12 gap-y-0 sm:grid-cols-2" data-reveal>
      {
        rest.map((industry) => (
          <li class="group border-t border-grey-300">
            <a href={`/industries/${industry.slug}`} class="grid gap-1.5 py-7">
              <div class="flex items-center justify-between gap-3">
                <h3 class="flex items-center gap-3 text-[length:var(--text-2xl)] leading-snug text-navy-700 transition-colors duration-[var(--duration-fast)] group-hover:text-orange-700">
                  <Icon name={industry.icon} size={22} class="shrink-0 text-orange-500" />
                  {industry.title}
                </h3>
                <Icon
                  name="arrow-right"
                  size={16}
                  class="shrink-0 text-grey-500 transition-all duration-[var(--duration-fast)] group-hover:text-orange-700 motion-safe:group-hover:translate-x-0.5"
                />
              </div>
              <p class="max-w-[50ch] pl-[2.1rem] text-base leading-relaxed text-ink">
                {industry.positioning}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section tone="deep" space="tight">
    <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="text-[length:var(--text-3xl)] text-paper">Work in a sector not listed?</h2>
        <p class="mt-3 max-w-[52ch] text-base text-navy-100">
          The model transfers. Tell us how your operation runs and what you are required to
          report, and we will tell you what is relevant.
        </p>
      </div>
      <Button href="/contact" variant="inverse" size="large" arrow>Talk to Us</Button>
    </div>
  </Section>
</BaseLayout>
