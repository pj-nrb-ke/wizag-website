---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import { industries } from '../../data/navigation';

const [lead, ...rest] = industries;
---

<BaseLayout
  title="Industries"
  description="Industry experience across manufacturing, financial services, retail and distribution, logistics, healthcare, education, professional services, NGOs and the public sector."
>
  <PageHero
    title="Industry experience that connects technology to operations"
    lead="The systems are similar across sectors. What differs is how the work actually flows — and that is where implementations succeed or fail."
    eyebrow="Industries"
    crumbs={[{ label: 'Home', href: '/' }]}
  />

  <Section tone="paper">
    <a
      href={lead!.href}
      class="group grid gap-6 border-t-2 border-navy-700 py-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:gap-12"
      data-reveal
    >
      <div>
        <Icon name="erp-systems" size={24} class="text-orange-500" />
        <h2
          class="mt-4 text-[length:var(--text-4xl)] leading-tight text-navy-700 transition-colors duration-[var(--duration-fast)] group-hover:text-orange-700"
        >
          {lead!.label}
        </h2>
      </div>
      <div>
        <p class="text-[length:var(--text-lg)] leading-relaxed text-ink">
          Our deepest sector experience. Manufacturing brings together everything the six
          practices cover — inventory, procurement, production, costing, quality and the
          reporting that has to reconcile across all of it.
        </p>
        <span
          class="mt-5 inline-flex items-center gap-1.5 text-base font-semibold text-navy-700 group-hover:text-orange-700"
        >
          Explore manufacturing
          <Icon name="arrow-right" size={16} />
        </span>
      </div>
    </a>

    <ul class="grid sm:grid-cols-2 sm:gap-x-12 lg:grid-cols-4" data-reveal>
      {
        rest.map((industry) => (
          <li>
            <a
              href={industry.href}
              class="group flex items-center justify-between gap-3 border-t border-grey-300 py-4 text-base font-medium text-navy-700 transition-colors duration-[var(--duration-fast)] hover:text-orange-700"
            >
              {industry.label}
              <Icon
                name="arrow-right"
                size={16}
                class="shrink-0 text-grey-500 transition-all duration-[var(--duration-fast)] group-hover:text-orange-700 motion-safe:group-hover:translate-x-0.5"
              />
            </a>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section tone="deep" space="tight">
    <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="text-[length:var(--text-3xl)] text-paper">Work in a sector not listed?</h2>
        <p class="mt-3 max-w-[52ch] text-base text-navy-100">
          The practices transfer. Tell us how your operation runs and we will tell you what
          is relevant.
        </p>
      </div>
      <Button href="/contact" variant="inverse" size="large" arrow>Talk to Us</Button>
    </div>
  </Section>
</BaseLayout>
