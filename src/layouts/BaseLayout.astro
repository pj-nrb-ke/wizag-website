---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import BackToTop from '../components/ui/BackToTop.astro';
import LogoSprite from '../components/ui/LogoSprite.astro';
import { company } from '../data/navigation';

interface Props {
  title: string;
  description: string;
  /** Thin/stub pages are kept out of the index until they have real content.
   *  Ten near-empty pages would drag the whole domain's quality signal down
   *  at exactly the moment we're consolidating wizag.co.ke into wizag.biz. */
  noindex?: boolean;
  /** Omits the site chrome — used by standalone pages if ever needed. */
  bare?: boolean;
}

const { title, description, noindex = false, bare = false } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://wizag.biz');
const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Fonts render the first paint, so they are preloaded ahead of the CSS
         that references them. crossorigin is required even same-origin. -->
    <link
      rel="preload"
      href="/fonts/source-serif-4-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-sans-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#1b306c" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${company.brand} — ${company.legalName}`} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Flags JS before first paint so reveal animations never flash their
         start state. Without JS, [data-reveal] content stays visible. -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>

  <body>
    {/* The destination for the back-to-top link. Focusable only
        programmatically, so following the link moves focus here and a
        keyboard user's next Tab resumes from the top of the page. */}
    <span id="top" tabindex="-1"></span>

    <LogoSprite />

    <a class="sr-only skip-link" href="#main">Skip to main content</a>

    {!bare && <Header />}

    <main id="main">
      <slot />
    </main>

    {!bare && <Footer />}

    {/* Last in the DOM so it comes last in the tab order — a control that
        jumps you back to the top belongs after the content, not before it.
        `position: fixed` means its placement on screen is unaffected. */}
    {!bare && <BackToTop />}

    <script>
      // Section reveal — one shared observer, fires once per element.
      // Guarded on reduced motion: those visitors get the finished state
      // immediately rather than a degraded animation.
      const wantsMotion = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
      const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');

      if (!wantsMotion || !('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-revealed'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delay = Number(el.dataset.revealDelay ?? 0);
              window.setTimeout(() => el.classList.add('is-revealed'), delay);
              observer.unobserve(el);
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        targets.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
