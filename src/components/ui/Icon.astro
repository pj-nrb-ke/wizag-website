  // AI & Intelligent Automation — a connected node network.
  'ai-automation': [
    'M12 4.5v4M12 15.5v4M6.7 7.5l2.8 2.3M14.5 14.2l2.8 2.3M17.3 7.5l-2.8 2.3M9.5 14.2l-2.8 2.3',
    'M12 9.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z',
    'M12 2.5a2 2 0 1 0 0 4 2 2 0 0 0 0-4ZM12 17.5a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z',
  ],
  // Process & Operational Excellence — work flowing between stages.
  'process-excellence': [
    'M3.5 5.5h7v5h-7z',
    'M13.5 13.5h7v5h-7z',
    'M7 10.5v4a2 2 0 0 0 2 2h4.5',
  ],
  // Data & BI — measurement.
  'data-analytics': [
    'M4 20V4',
    'M4 20h16',
    'M8 20v-5.5M12.5 20V9M17 20v-8',
  ],
  // Managed Technology Services — continuous protection and oversight.
  'managed-services': [
    'M12 3.5 4.5 6.5v5.2c0 4.3 3 7.4 7.5 8.8 4.5-1.4 7.5-4.5 7.5-8.8V6.5z',
    'm9 12 2.2 2.2L15.5 10',
  ],

  /* --- project delivery (TeamKazi) ------------------------------------ */
  // Schedule — staggered Gantt bars against a time axis.
  schedule: [
    'M3.5 4.5v15',
    'M6.5 8.5h6.5',
    'M10 12.5h7.5',
    'M8 16.5h5.5',
  ],
  // Timesheets — hours, and what they cost.
  timesheet: ['M12 4a8 8 0 1 0 0 16 8 8 0 0 0 0-16Z', 'M12 7.5V12l3 2'],
