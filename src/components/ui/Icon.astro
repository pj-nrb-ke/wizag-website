---
/**
 * One icon system for the whole site (brief §19: "use one consistent icon
 * system"). All icons are 24×24, 1.5px stroke, currentColor, no fill —
 * drawn to the same optical weight so a row of them reads as a set rather
 * than a collection.
 *
 * Icons are decorative by default and hidden from assistive tech. Pass a
 * `title` only when the icon is the sole carrier of meaning.
 */
interface Props {
  name: IconName;
  size?: number;
  class?: string;
  title?: string;
}

const STROKE_ICONS = {
  /* --- interface ------------------------------------------------------ */
  'arrow-right': ['M4 12h15', 'M13 5.5 19.5 12 13 18.5'],
  'arrow-up-right': ['M7 17 17 7', 'M8.5 7H17v8.5'],
  'chevron-down': ['m5.5 9 6.5 6.5L18.5 9'],
