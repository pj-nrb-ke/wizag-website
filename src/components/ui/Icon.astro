const FILL_ICONS = {
  linkedin:
    'M4.98 3.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM3 9h4v12H3zM9.5 9h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05 4.02 0 4.76 2.6 4.76 6V21h-4v-5.5c0-1.3-.02-3-1.85-3-1.85 0-2.13 1.44-2.13 2.9V21h-4z',
} as const;

export type IconName = keyof typeof STROKE_ICONS | keyof typeof FILL_ICONS;

const { name, size = 24, class: className = '', title } = Astro.props;

const isFilled = name in FILL_ICONS;
const strokePaths = (STROKE_ICONS as Record<string, readonly string[]>)[name];
const fillPath = (FILL_ICONS as Record<string, string>)[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFilled ? 'currentColor' : 'none'}
  stroke={isFilled ? 'none' : 'currentColor'}
  stroke-width={isFilled ? undefined : 1.5}
  stroke-linecap={isFilled ? undefined : 'round'}
  stroke-linejoin={isFilled ? undefined : 'round'}
  class:list={['shrink-0', className]}
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  focusable="false"
>
  {title && <title>{title}</title>}
  {isFilled ? <path d={fillPath} /> : strokePaths?.map((d) => <path d={d} />)}
</svg>
