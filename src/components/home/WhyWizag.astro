---
import Section from '../layout/Section.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { differentiators } from '../../data/home';

/**
 * Why WIZAG (brief §8.9).
 *
 * Editorial treatment: large serif sub-heads carrying the weight, no icons
 * at all. The brief asks for strong typography and minimal icon use (§8.9),
 * and after the icon-led services and industries sections the page needs a
 * quieter, more confident register here.
 */
---

<Section tone="paper" id="why">
  <SectionHeading
    eyebrow="Why WIZAG"
    measure="max-w-[16ch]"
    class="max-w-3xl"
    data-reveal
  >
    More than a technology vendor
  </SectionHeading>

  <div class="@@mt-6@@ grid gap-x-16 gap-y-0 md:grid-cols-2">
    {
      differentiators.map((item, i) => (
        <div
          class="border-t border-grey-300 py-8"
          data-reveal
          data-reveal-delay={(i % 2) * 80}
        >
          <h3 class="text-[length:var(--text-3xl)] leading-snug text-navy-700">{item.title}</h3>
          <p class="mt-3 max-w-[46ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
            {item.body}
          </p>
        </div>
      ))
    }
  </div>
</Section>
