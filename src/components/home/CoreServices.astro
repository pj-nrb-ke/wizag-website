---
import Section from '../layout/Section.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';
import { coreServices } from '../../data/home';

/**
 * Core services (brief §8.4).
 *
 * A disciplined three-column grid, but the items are rule-separated rather
 * than boxed — the brief asks explicitly for a grid that avoids making every
 * item look like a generic product card (§8.4), and six shadowed cards is
 * exactly the SaaS pattern §3.2 rules out.
 *
 * Each item carries the four required elements: name, one-line value
 * proposition, business outcome, and a link through.
 */
---

<Section tone="paper" id="services">
  <SectionHeading
    eyebrow="What we do"
    lead="From strategy and ERP to AI, operations, data and ongoing support, WIZAG brings together the capabilities organisations need to keep improving performance."
    measure="max-w-[24ch]"
    class="max-w-3xl"
    data-reveal
  >
    One partner across your technology journey
  </SectionHeading>

  <ul class="@@mt-6@@ grid gap-x-10 gap-y-0 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-12">
    {
      coreServices.map((service, i) => (
        <li
          class="group border-t border-grey-300 py-7 lg:py-8"
          data-reveal
          data-reveal-delay={Math.min(i, 3) * 60}
        >
          <a href={service.href} class="block">
            <Icon name={service.icon} size={22} class="text-orange-500" />

            <h3 class="mt-4 text-[length:var(--text-2xl)] leading-snug text-navy-700">
              {service.name}
            </h3>

            <p class="mt-3 text-base leading-relaxed text-ink">{service.value}</p>

            <p class="mt-4 flex items-start gap-2 text-base font-semibold text-navy-700">
              <Icon name="check" size={17} class="mt-0.5 text-orange-700" />
              {service.outcome}
            </p>

            <span
              class="mt-5 inline-flex items-center gap-1.5 text-base font-semibold
                     text-navy-700 underline-offset-4 transition-colors
                     duration-[var(--duration-fast)] group-hover:text-orange-700
                     group-hover:underline"
            >
              Learn more
              <Icon
                name="arrow-right"
                size={16}
                class="transition-transform duration-[var(--duration-fast)] motion-safe:group-hover:translate-x-0.5"
              />
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</Section>
