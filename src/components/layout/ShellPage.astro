---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from './PageHero.astro';
import Section from './Section.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

/**
 * Structured shell for pages whose detailed content is still being written.
 *
 * Deliberately honest: a real heading, a real description of what the page
 * covers, and a route to a conversation — never filler text, and never
 * invented detail. Pages using this are `noindex` until they carry real
 * content, so ten thin pages cannot drag down the domain's quality signal
 * while wizag.co.ke is being consolidated into wizag.biz.
 */
interface Props {
  title: string;
  description: string;
  lead?: string;
  eyebrow?: string;
  crumbs?: { label: string; href: string }[];
  /** Bullet points describing what this page will cover. */
  covers?: string[];
  /** Set false once real content lands so the page becomes indexable. */
  noindex?: boolean;
}

const {
  title,
  description,
  lead,
  eyebrow,
  crumbs = [],
  covers = [],
  noindex = true,
} = Astro.props as Props;
---

<BaseLayout title={title} description={description} noindex={noindex}>
  <PageHero title={title} lead={lead} eyebrow={eyebrow} crumbs={crumbs} />

  {
    covers.length > 0 && (
      <Section tone="paper">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:gap-16">
          <div data-reveal>
            <p class="eyebrow mb-4 text-ink-soft">What this covers</p>
            <p class="max-w-[36ch] text-[length:var(--text-lg)] leading-relaxed text-ink">
              Detailed content for this page is in preparation. In the meantime, here is what
              it covers — and we are happy to talk it through directly.
            </p>
          </div>

          <ul class="grid gap-x-10 gap-y-0 sm:grid-cols-2" data-reveal data-reveal-delay="100">
            {covers.map((item) => (
              <li class="flex items-start gap-3 border-t border-grey-300 py-3.5 text-base text-ink">
                <Icon name="check" size={16} class="mt-1 shrink-0 text-orange-700" />
                {item}
              </li>
            ))}
          </ul>
        </div>
      </Section>
    )
  }

  <Section tone="deep" space="tight">
    <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="text-[length:var(--text-3xl)] text-paper">Want the detail sooner?</h2>
        <p class="mt-3 max-w-[52ch] text-base text-navy-100">
          Ask us directly. We would rather answer your actual question than have you read a
          page that only half covers it.
        </p>
      </div>
      <Button href="/contact" variant="inverse" size="large" arrow>Talk to Us</Button>
    </div>
  </Section>
</BaseLayout>
