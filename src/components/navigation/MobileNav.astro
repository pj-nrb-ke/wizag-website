---
import Icon from '../ui/Icon.astro';
import Logo from '../ui/Logo.astro';
import { primaryNav, primaryCta, company } from '../../data/navigation';

/**
 * Mobile / tablet navigation drawer (below 1024px — see DesktopNav for why
 * the full bar cannot fit below that).
 *
 * Sections use native <details>/<summary> accordions: keyboard and screen
 * reader behaviour comes free and correct, and the menu still works if the
 * drawer script fails. Open/close, focus trapping and scroll lock are
 * handled in Header.astro.
 */
const slugify = (label: string) => label.toLowerCase().replace(/[^a-z]+/g, '-');
---

<!-- Toggle lives in the header bar -->
<button
  type="button"
  class="-mr-2 flex items-center justify-center rounded-[var(--radius-sm)] p-2.5 text-navy-700
         transition-colors duration-[var(--duration-fast)] hover:bg-navy-50 lg:hidden"
  aria-expanded="false"
  aria-controls="mobile-drawer"
  aria-label="Open menu"
  data-drawer-toggle
>
  <Icon name="menu" size={20} />
</button>

<!-- Backdrop -->
<div
  class="fixed inset-0 z-40 bg-navy-950/40 opacity-0 transition-opacity
         duration-[var(--duration-base)] lg:hidden"
  data-drawer-backdrop
  hidden
>
</div>

<!-- Drawer -->
<div
  id="mobile-drawer"
  class="fixed inset-y-0 right-0 z-50 flex w-full max-w-sm translate-x-full flex-col
         bg-paper shadow-[var(--shadow-panel)] transition-transform
         duration-[var(--duration-base)] ease-[var(--ease-out)] lg:hidden"
  data-drawer-panel
  aria-label="Primary"
  hidden
>
  <div class="flex items-center justify-between border-b border-grey-100 px-5 py-4">
    <a href="/" class="text-navy-700" aria-label={`${company.brand} home`}>
      <Logo height={28} decorative />
    </a>
    <button
      type="button"
      class="-mr-2 rounded-[var(--radius-sm)] p-2.5 text-navy-700 transition-colors
             duration-[var(--duration-fast)] hover:bg-navy-50"
      aria-label="Close menu"
      data-drawer-close
    >
      <Icon name="close" size={20} />
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto overscroll-contain px-3 py-4" aria-label="Mobile">
    <ul class="space-y-0.5">
      {
        primaryNav.map((item) =>
          item.children ? (
            <li>
              <details class="group" name={`m-${slugify(item.label)}`}>
                <summary
                  class="flex cursor-pointer list-none items-center justify-between gap-2
                         rounded-[var(--radius-sm)] px-4 py-3 font-semibold text-navy-700
                         marker:hidden hover:bg-navy-50 [&::-webkit-details-marker]:hidden"
                >
                  {item.label}
                  <Icon
                    name="chevron-down"
                    size={16}
                    class="text-ink-soft transition-transform duration-[var(--duration-fast)] group-open:rotate-180"
                  />
                </summary>
                <ul class="mb-1 ml-4 space-y-0.5 border-l border-grey-100 pl-3">
                  {item.children.map((child) => (
                    <li class:list={[child.dividerBefore && 'mt-1.5 border-t border-grey-100 pt-1.5']}>
                      <a
                        href={child.href}
                        class="block rounded-[var(--radius-sm)] px-4 py-2.5 text-base
                               text-ink transition-colors duration-[var(--duration-fast)]
                               hover:bg-navy-50 hover:text-navy-700"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                  <li class="mt-1.5 border-t border-grey-100 pt-1.5">
                    <a
                      href={item.href}
                      class="block rounded-[var(--radius-sm)] px-4 py-2.5 text-base
                             font-semibold text-navy-700 hover:bg-navy-50"
                    >
                      All {item.label}
                    </a>
                  </li>
                </ul>
              </details>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class="block rounded-[var(--radius-sm)] px-4 py-3 font-semibold text-navy-700
                       transition-colors duration-[var(--duration-fast)] hover:bg-navy-50"
              >
                {item.label}
              </a>
            </li>
          )
        )
      }
    </ul>
  </nav>

  <div class="border-t border-grey-100 px-5 py-4">
    <a
      href={primaryCta.href}
      class="flex w-full items-center justify-center gap-2 rounded-[var(--radius-sm)]
             bg-navy-700 px-5 py-3.5 font-semibold text-paper transition-colors
             duration-[var(--duration-fast)] hover:bg-navy-800"
    >
      {primaryCta.shortLabel}
      <Icon name="arrow-right" size={16} />
    </a>
    <a
      href={`mailto:${company.email}`}
      class="mt-3 flex items-center justify-center gap-2 text-sm text-ink-soft
             transition-colors hover:text-navy-700"
    >
      <Icon name="mail" size={16} />
      {company.email}
    </a>
  </div>
</div>
