---
import { captureFields } from '../../data/wizcrm';

/**
 * AI Visit Capture — the hero demo.
 *
 * WHY THIS INSTEAD OF AN "AI ILLUSTRATION"
 * The request was for artwork showing "what this app can do with the power
 * of AI". Rendered literally that becomes a robot, a glowing brain or a
 * neural-network mesh — the exact imagery the WIZAG brief bans (§3.2), and
 * imagery that says nothing a competitor could not also claim.
 *
 * This shows the product instead. A rep speaks for twenty seconds; a
 * structured report assembles itself, field by field, in front of you. The
 * whole proposition — "the CRM that writes itself" — is demonstrated rather
 * than asserted, and it is the one thing no competitor screenshot can copy
 * without having built the feature.
 *
 * Motion is the message here, not decoration, so it earns its place under
 * the site's restrained-animation rule. Fully static under
 * prefers-reduced-motion, where every field simply shows filled in — the
 * end state is the useful one.
 *
 * Real text throughout: legible at any size, reflows on a phone, and reads
 * in order to a screen reader.
 */
---

<figure class="demo" aria-labelledby="demo-cap">
  <figcaption id="demo-cap" class="sr-only">
    A demonstration of AI Visit Capture: a sales rep speaks for twenty seconds after a
    customer visit, and WizCRM drafts a structured report — outcome, who was met, competitor
    mentioned, objection raised, next step and due date — with every field editable before
    saving.
  </figcaption>

  <!-- App chrome -->
  <div class="bar" aria-hidden="true">
    <span class="bar-dot"></span>
    <span class="bar-title">WizCRM · Visit report</span>
    <span class="bar-right">Offline ready</span>
  </div>

  <!-- The rep speaking -->
  <div class="speak" aria-hidden="true">
    <span class="mic">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
           stroke-linecap="round" stroke-linejoin="round" width="17" height="17">
        <path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"></path>
        <path d="M19 10v1a7 7 0 0 1-14 0v-1M12 18v4"></path>
      </svg>
    </span>

    <span class="wave">
      {
        Array.from({ length: 22 }).map((_, i) => (
          <i style={`--i:${i}`}></i>
        ))
      }
    </span>

    <span class="secs">0:21</span>
  </div>

  <p class="said" aria-hidden="true">
    “Met Grace at procurement, they’re keen but worried about lead times on bulk. Wants a
    proposal by Thursday. They’re still with their old supplier.”
  </p>

  <!-- What the AI drafts -->
  <div class="drafted">
    <p class="drafted-head" aria-hidden="true">
      <span class="spark"></span>
      Drafted by AI · every field editable
    </p>

    <dl class="fields">
      {
        captureFields.map((field, i) => (
          <div class="field" style={`--i:${i}`}>
            <dt>{field.label}</dt>
            <dd>{field.value}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</figure>

<style>
  .demo {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: linear-gradient(168deg, var(--color-navy-700) 0%, var(--color-navy-900) 100%);
    box-shadow: var(--shadow-panel);
    color: #fff;
  }

  /* ---- chrome ---- */
  .bar {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(255, 255, 255, 0.04);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .bar-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-orange-500);
    flex: none;
  }

  .bar-title {
    color: rgba(255, 255, 255, 0.9);
  }

  .bar-right {
    margin-left: auto;
    text-transform: none;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  /* ---- the rep speaking ---- */
  .speak {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.15rem 1.25rem 0.9rem;
  }

  .mic {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(247, 157, 7, 0.16);
    color: var(--color-orange-500);
    flex: none;
  }

  .wave {
    display: flex;
    align-items: center;
    gap: 3px;
    height: 26px;
    flex: 1;
    min-width: 0;
  }

  .wave i {
    flex: 1;
    min-width: 2px;
    height: 30%;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.32);
    transform-origin: center;
  }

  .secs {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.55);
    flex: none;
  }

  .said {
    margin: 0 1.25rem;
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ---- the drafted report ---- */
  .drafted {
    padding: 1.15rem 1.25rem 1.3rem;
  }

  .drafted-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--color-orange-500);
  }

  .spark {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-orange-500);
    flex: none;
  }

  .fields {
    display: grid;
    gap: 0.4rem;
    margin: 0;
  }

  .field {
    display: grid;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    gap: 0.75rem;
    align-items: baseline;
    padding: 0.5rem 0.7rem;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .field dt {
    font-size: var(--text-2xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  .field dd {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.92);
  }

  @media (max-width: 420px) {
    .field {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }

  /* ---- motion -------------------------------------------------------
     Everything above renders complete and readable with no animation at
     all. The motion below only stages it. */
  @media (prefers-reduced-motion: no-preference) {
    .wave i {
      animation: wave 1.1s ease-in-out infinite alternate;
      animation-delay: calc(var(--i) * -0.09s);
    }

    /* Each field runs the same 15s cycle, offset by its position, so they
       appear one after another and clear together before the loop repeats.
       Offsetting the DELAY rather than writing per-field keyframes keeps
       this to one rule. */
    .field {
      animation: field-in 15s ease-out infinite;
      animation-delay: calc(var(--i) * 0.5s);
      opacity: 0;
    }

    .spark {
      animation: spark 2.4s ease-in-out infinite;
    }
  }

  @keyframes wave {
    from {
      transform: scaleY(0.35);
    }
    to {
      transform: scaleY(1);
    }
  }

  @keyframes field-in {
    0%,
    7% {
      opacity: 0;
      transform: translateY(6px);
    }
    12%,
    74% {
      opacity: 1;
      transform: translateY(0);
    }
    82%,
    100% {
      opacity: 0;
      transform: translateY(0);
    }
  }

  @keyframes spark {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
</style>
