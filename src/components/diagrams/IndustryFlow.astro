---
interface Stage {
  stage: string;
  strain: string;
}

interface Props {
  stages: Stage[];
  /** Names the cycle, e.g. "Procure to close". Shown as a chip. */
  label: string;
  /** Seconds for one full pass. */
  cycle?: number;
}

/**
 * The operating cycle of a sector, and where it strains.
 *
 * WHY THIS DIAGRAM EXISTS
 * The industry pages have to prove, in the first screen, that WIZAG
 * understands how the reader's business actually runs. A list of
 * capabilities cannot do that — every competitor has the same list. A
 * picture of the reader's own operating cycle, with the friction named at
 * each link, can: a manufacturer who sees "Procure → Produce → Cost → Sell
 * → Close" with the right pain under each stage concludes we have been in a
 * business like theirs, before we have claimed anything.
 *
 * The backbone (the stages) is the neutral, universal cycle for the sector.
 * The strain line under each stage is the honest part — what goes wrong at
 * that link when the systems do not join up. Backbone positive, caption
 * truthful: the same recognition-first logic as PracticeShift.
 *
 * A pulse travels the spine so the eye reads it as a cycle rather than a
 * row of boxes. The motion is meaning, not decoration — this is a loop the
 * business runs continuously, and the animation says "continuously".
 *
 * Horizontal spine on desktop, vertical on mobile. Fully static and
 * readable under prefers-reduced-motion, every stage resolved and lit.
 */
const { stages, label, cycle = 15 } = Astro.props as Props;

/* Land the last node around 55% of the cycle, leaving a hold on the
   complete diagram. */
const stagger = ((cycle * 0.55) / Math.max(stages.length, 1)).toFixed(2);
---

<figure class="chain" style={`--cycle:${cycle}s; --stagger:${stagger}s; --n:${stages.length}`}>
  <figcaption class="sr-only">
    The {label} cycle, and where it strains without joined-up systems.
    {stages.map((s) => `${s.stage}: ${s.strain}.`).join(' ')}
  </figcaption>

  <p class="chain-label" aria-hidden="true">{label}</p>

  <ol class="chain-track">
    {
      stages.map((s, i) => (
        <li class="link" style={`--i:${i}`}>
          <div class="node" aria-hidden="true">
            <span class="dot" />
            {i < stages.length - 1 && <span class="rail" />}
          </div>
          <div class="link-body">
            <h3 class="stage">{s.stage}</h3>
            <p class="strain">{s.strain}</p>
          </div>
        </li>
      ))
    }
  </ol>
</figure>

<style>
  .chain {
    margin: 0;
    padding: 0;
  }

  .chain-label {
    display: inline-block;
    margin: 0 0 1.6rem;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    background: var(--color-navy-700);
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .chain-track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .link {
    display: grid;
    position: relative;
  }

  /* ---------- mobile: vertical spine on the left ---------- */
  .link {
    grid-template-columns: 1.75rem minmax(0, 1fr);
    gap: 0 1rem;
    padding-bottom: 1.5rem;
  }

  .link:last-child {
    padding-bottom: 0;
  }

  .node {
    position: relative;
    grid-row: 1 / span 2;
    display: flex;
    justify-content: center;
  }

  .dot {
    position: relative;
    z-index: 1;
    width: 0.85rem;
    height: 0.85rem;
    margin-top: 0.35rem;
    border-radius: 50%;
    background: var(--color-paper);
    border: 2px solid var(--color-grey-300);
  }

  .rail {
    position: absolute;
    top: 1.2rem;
    bottom: -1.5rem;
    left: calc(50% - 1px);
    width: 2px;
    background: var(--color-grey-300);
    transform-origin: top center;
  }

  .link-body {
    padding-bottom: 0.2rem;
  }

  .stage {
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-navy-700);
  }

  .strain {
    margin-top: 0.4rem;
    padding-left: 0.7rem;
    border-left: 2px solid var(--color-orange-300);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  /* ---------- desktop: horizontal spine ---------- */
  @media (min-width: 60rem) {
    .chain-track {
      grid-template-columns: repeat(var(--n), minmax(0, 1fr));
    }

    .link {
      grid-template-columns: none;
      grid-template-rows: 1.75rem auto;
      gap: 0.9rem 0;
      padding-bottom: 0;
      padding-right: 1.1rem;
    }

    .node {
      grid-row: auto;
      justify-content: flex-start;
    }

    .dot {
      margin-top: 0.45rem;
    }

    .rail {
      top: calc(0.45rem + 0.42rem - 1px);
      bottom: auto;
      left: 0.85rem;
      right: -0.25rem;
      width: auto;
      height: 2px;
      transform-origin: left center;
    }

    .link:last-child .rail {
      display: none;
    }

    .strain {
      border-left: none;
      padding-left: 0;
      padding-top: 0.55rem;
      border-top: 2px solid var(--color-orange-300);
      max-width: 15rem;
    }
  }

  /* ---------- motion: staging only, diagram is complete without it ------ */
  @media (prefers-reduced-motion: no-preference) {
    .dot {
      animation: dot-lit var(--cycle) ease-out infinite;
      animation-delay: calc(var(--i) * var(--stagger));
    }

    .link-body {
      animation: body-in var(--cycle) ease-out infinite;
      animation-delay: calc(var(--i) * var(--stagger));
    }

    .rail {
      animation: rail-y var(--cycle) ease-out infinite;
      animation-delay: calc(var(--i) * var(--stagger) + 0.2s);
    }

    @media (min-width: 60rem) {
      .rail {
        animation-name: rail-x;
      }
    }
  }

  @keyframes dot-lit {
    0%,
    4% {
      background: var(--color-paper);
      border-color: var(--color-grey-300);
      transform: scale(1);
    }
    11%,
    88% {
      background: var(--color-orange-500);
      border-color: var(--color-orange-500);
      transform: scale(1.12);
    }
    96%,
    100% {
      background: var(--color-paper);
      border-color: var(--color-grey-300);
      transform: scale(1);
    }
  }

  @keyframes body-in {
    0%,
    3% {
      opacity: 0.4;
    }
    11%,
    100% {
      opacity: 1;
    }
  }

  @keyframes rail-x {
    0%,
    6% {
      transform: scaleX(0);
    }
    18%,
    90% {
      transform: scaleX(1);
    }
    97%,
    100% {
      transform: scaleX(0);
    }
  }

  @keyframes rail-y {
    0%,
    6% {
      transform: scaleY(0);
    }
    18%,
    90% {
      transform: scaleY(1);
    }
    97%,
    100% {
      transform: scaleY(0);
    }
  }
</style>
