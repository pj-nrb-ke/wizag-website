---
import Icon from '../ui/Icon.astro';
import type { IconName } from '../ui/Icon.astro';

/**
 * Enterprise service ecosystem (brief §8.2) — the hero visual.
 *
 * REBUILT. The previous version was a light grey box containing a navy bar,
 * four outlined rectangles and two straight connector lines. It was
 * structurally correct and visually worthless — SmartArt, not design. The
 * design audit called it "a placeholder" (§2.1) and the client called the
 * whole site a school project. Both were right, and this element was the
 * loudest evidence.
 *
 * What changed, and why each choice earns its place:
 *
 *  — DARK GROUND. The page is white per brief §3.1, so the one dark object
 *    in the hero becomes the focal point by contrast alone. It is also the
 *    honest answer to having no photography: a dark, dense panel carries a
 *    hero composition where a pale outlined box cannot.
 *
 *  — DEPTH. Nodes sit on a lighter surface with a hairline top highlight,
 *    so they read as raised rather than drawn. This is the difference
 *    between a diagram and a wireframe.
 *
 *  — CURVED CONNECTORS. Real SVG paths that fan from the strategy node to
 *    each capability and converge again into outcomes. Straight CSS rules
 *    read as a flowchart; curves read as a system.
 *
 *  — A LIVE EDGE. A quiet status strip and a small outcome bar chart give
 *    the panel something to look at beyond labels — the thing that makes a
 *    graphic feel built rather than sketched.
 *
 * Still real HTML text, so it stays legible at any size, reflows on small
 * screens and reads sensibly to assistive tech. The SVG is decorative only.
 */

const capabilities: { label: string; icon: IconName; meta: string }[] = [
  { label: 'ERP & Business Systems', icon: 'erp-systems', meta: 'Finance · Stock · Procurement' },
  { label: 'AI & Automation', icon: 'ai-automation', meta: 'Forecasting · Documents' },
  { label: 'Data & Analytics', icon: 'data-analytics', meta: 'Dashboards · Reporting' },
  { label: 'Managed Services', icon: 'managed-services', meta: 'Support · Continuity' },
];

/* Illustrative shape only — a rising trend, deliberately unlabelled. No
   figure, percentage or claim appears anywhere in this graphic (brief
   §8.11, §3.2). */
const trend = [34, 42, 39, 51, 58, 64, 73, 81];
---

<figure class="eco" aria-labelledby="eco-desc">
  <figcaption id="eco-desc" class="sr-only">
    How WIZAG works: business strategy directs four coordinated capabilities — ERP and
    business systems, AI and automation, data and analytics, and managed services — which
    together produce measurable business outcomes.
  </figcaption>

  <!-- Status strip -->
  <div class="eco-bar" aria-hidden="true">
    <span class="eco-dot"></span>
    <span class="eco-bar-label">Connected Intelligence</span>
    <span class="eco-bar-right">One accountable partner</span>
  </div>

  <div class="eco-body">
    <!-- Direction -->
    <div class="node node--lead">
      <Icon name="exec-technology" size={17} class="shrink-0 text-orange-500" />
      <span>Business Strategy</span>
    </div>

    <!-- Fan out: strategy into four capabilities -->
    <div class="wire wire--out" aria-hidden="true">
      <svg viewBox="0 0 300 44" preserveAspectRatio="none" focusable="false">
        <defs>
          <linearGradient id="ecoDown" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--color-orange-500)" stop-opacity="0.85"></stop>
            <stop offset="100%" stop-color="var(--color-navy-300)" stop-opacity="0.5"></stop>
          </linearGradient>
        </defs>
        <path d="M150 0 V14 Q150 24 132 24 H82 Q64 24 64 34 V44" />
        <path d="M150 0 V14 Q150 24 141 24 H124 Q115 24 115 34 V44" />
        <path d="M150 0 V14 Q150 24 159 24 H176 Q185 24 185 34 V44" />
        <path d="M150 0 V14 Q150 24 168 24 H218 Q236 24 236 34 V44" />
      </svg>
    </div>

    <!-- Delivery capabilities -->
    <ul class="grid grid-cols-1 gap-2.5 sm:grid-cols-2">
      {
        capabilities.map((capability) => (
          <li class="node node--cap">
            <Icon name={capability.icon} size={17} class="shrink-0 text-orange-500" />
            <span class="min-w-0">
              <span class="node-label">{capability.label}</span>
              <span class="node-meta">{capability.meta}</span>
            </span>
          </li>
        ))
      }
    </ul>

    <!-- Converge into outcomes -->
    <div class="wire wire--in" aria-hidden="true">
      <svg viewBox="0 0 300 40" preserveAspectRatio="none" focusable="false">
        <defs>
          <linearGradient id="ecoUp" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--color-navy-300)" stop-opacity="0.5"></stop>
            <stop offset="100%" stop-color="var(--color-orange-500)" stop-opacity="0.9"></stop>
          </linearGradient>
        </defs>
        <path d="M64 0 V10 Q64 20 82 20 H132 Q150 20 150 30 V40" />
        <path d="M115 0 V10 Q115 20 124 20 H141 Q150 20 150 30 V40" />
        <path d="M185 0 V10 Q185 20 176 20 H159 Q150 20 150 30 V40" />
        <path d="M236 0 V10 Q236 20 218 20 H168 Q150 20 150 30 V40" />
      </svg>
    </div>

    <!-- Result -->
    <div class="node node--out">
      <span class="node-label">Measurable Business Outcomes</span>
      <span class="spark" aria-hidden="true">
        {trend.map((v) => <i style={`height:${v}%`}></i>)}
      </span>
    </div>
  </div>
</figure>

<style>
  /* ---- Panel -------------------------------------------------------- */
  .eco {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background:
      radial-gradient(120% 80% at 50% -10%, rgba(247, 157, 7, 0.14), transparent 60%),
      linear-gradient(168deg, var(--color-navy-700) 0%, var(--color-navy-900) 100%);
    box-shadow: var(--shadow-panel);
  }

  /* ---- Status strip -------------------------------------------------- */
  .eco-bar {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(255, 255, 255, 0.035);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
  }

  .eco-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-orange-500);
    box-shadow: 0 0 0 3px rgba(247, 157, 7, 0.18);
    flex: none;
  }

  .eco-bar-label {
    color: rgba(255, 255, 255, 0.9);
  }

  .eco-bar-right {
    margin-left: auto;
    letter-spacing: 0.06em;
    text-transform: none;
    font-weight: 500;
    display: none;
  }

  @media (min-width: 420px) {
    .eco-bar-right {
      display: block;
    }
  }

  .eco-body {
    padding: 1.4rem 1.15rem 1.5rem;
  }

  @media (min-width: 640px) {
    .eco-body {
      padding: 1.75rem 1.6rem 1.85rem;
    }
  }

  /* ---- Nodes ---------------------------------------------------------
     Raised surfaces, not outlines: a lighter fill, a hairline border, and a
     1px top highlight so light appears to fall from above. */
  .node {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    border-radius: var(--radius-md);
    padding: 0.8rem 0.95rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.07) inset, 0 6px 16px -10px rgba(0, 0, 0, 0.7);
  }

  .node--lead {
    justify-content: center;
    margin: 0 8%;
    background: rgba(255, 255, 255, 0.11);
    border-color: rgba(255, 255, 255, 0.17);
    font-weight: 650;
    font-size: var(--text-sm);
  }

  .node--cap {
    height: 100%;
    align-items: flex-start;
  }

  .node-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 650;
    line-height: 1.25;
  }

  .node-meta {
    display: block;
    margin-top: 0.15rem;
    font-size: var(--text-2xs);
    font-weight: 500;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.55);
  }

  /* The outcome carries the accent — the eye should finish here. */
  .node--out {
    margin: 0 2%;
    justify-content: space-between;
    gap: 1rem;
    background: rgba(247, 157, 7, 0.13);
    border-color: rgba(247, 157, 7, 0.42);
  }

  /* ---- Connectors ---------------------------------------------------- */
  .wire {
    height: 2.4rem;
  }

  .wire svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .wire path {
    fill: none;
    stroke-width: 1.25;
    vector-effect: non-scaling-stroke;
    stroke-linecap: round;
  }

  .wire--out path {
    stroke: url(#ecoDown);
  }

  .wire--in path {
    stroke: url(#ecoUp);
  }

  .wire--in {
    height: 2.2rem;
  }

  /* ---- Outcome sparkline ---------------------------------------------
     Shape only, no scale and no figures — it signals "measured" without
     making a claim the site cannot support. */
  .spark {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 22px;
    width: 62px;
    flex: none;
  }

  .spark i {
    flex: 1;
    border-radius: 1px;
    background: var(--color-orange-500);
    opacity: 0.55;
  }

  .spark i:nth-last-child(-n + 3) {
    opacity: 1;
  }

  /* Single column on the narrowest phones: the 2×2 grid crowds below
     ~380px once the meta line is in. */
  @media (max-width: 400px) {
    .node--lead,
    .node--out {
      margin: 0;
    }
  }
</style>
